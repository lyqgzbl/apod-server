# NASA
NASA_API_KEY=DEMO_KEY

# Runtime and logging
APP_ENV=development
LOG_LEVEL=debug
LOG_COLOR=true

# API authentication
API_AUTH_KEY=changeme
DEMO_KEY_LIMIT_PER_24H=5

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# API rate limit
API_RATE_LIMIT_RPS=8
API_RATE_LIMIT_BURST=16

# Memory cache
MEMORY_CACHE_TTL_MINUTES=180
MEMORY_CACHE_MAX_ITEMS=2000
MEMORY_CACHE_CLEANUP_MINUTES=15

# Image cache
IMAGE_CACHE_DIR=cache/images
IMAGE_CACHE_MAX_FILES=1000
IMAGE_CACHE_MAX_AGE_HOURS=720
